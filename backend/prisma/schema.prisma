// Smart Collab — database schema
// Foundation subgoal locks: User columns and Role enum. Later subgoals must
// add new tables/columns only, never alter existing User fields.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  project_manager
  team_member
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(team_member)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions   Session[]
  activities ActivityLog[]
  projects   Project[]     @relation("ProjectCreatedBy")

  @@index([role])
  @@map("users")
}

enum ProjectStatus {
  active
  completed
  on_hold
}

model Project {
  id          String        @id @default(uuid()) @db.Uuid
  name        String
  description String?
  deadline    DateTime
  status      ProjectStatus @default(active)
  createdBy   String        @db.Uuid
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  creator User @relation("ProjectCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([status, createdAt])
  @@index([deadline])
  @@index([createdBy])
  @@map("projects")
}

model Session {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  refreshTokenHash String   @unique
  userAgent        String?
  ip               String?
  createdAt        DateTime @default(now())
  expiresAt        DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @db.Uuid
  action    String
  meta      Json?
  createdAt DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorId])
  @@map("activity_logs")
}
