# Public env vars exposed to the browser (NEXT_PUBLIC_* only).
# Copy to .env.local for dev.
#
# Local dev:   http://localhost:4000
# Vercel prod: set in Vercel project → Settings → Environment Variables
#              to the deployed Render backend URL, e.g.
#              https://<service>.onrender.com  (no trailing slash)

NEXT_PUBLIC_API_URL=http://localhost:4000
