# ─────────────────────────────────────────────────────────────────────────────
# Backend
# ─────────────────────────────────────────────────────────────────────────────

# Node env
NODE_ENV=development
PORT=4000

# Postgres (matches docker-compose.yml service)
DATABASE_URL=postgresql://smartcollab:smartcollab@localhost:5433/smartcollab?schema=public

# JWT secrets — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-me-with-strong-random-string
JWT_REFRESH_SECRET=replace-me-with-a-different-strong-random-string

# Token TTLs (ms / s / m / h / d accepted by ms-style parser)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# CORS — comma-separated allowlist; no wildcards in prod
CORS_ORIGINS=http://localhost:3000

# Cookie domain — localhost for dev, your apex domain in prod
COOKIE_DOMAIN=localhost

# Demo seed passwords — read by prisma/seed.ts, exposed via README
DEMO_ADMIN_PW=demo-admin-pass
DEMO_PM_PW=demo-pm-pass
DEMO_MEMBER_PW=demo-member-pass

# Email (transactional sends for mention/assign/comment notifications)
# EMAIL_PROVIDER: one of "stub" | "resend" | "smtp"
#   - stub   = no real send, records to in-memory buffer (default; safe for dev/test)
#   - resend = uses Resend API (https://resend.com)
#   - smtp   = generic SMTP via nodemailer (Mailtrap, Gmail, Postfix, etc.)
EMAIL_PROVIDER=stub
EMAIL_FROM=noreply@smart-collab.local

# Resend (only required when EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# SMTP (only required when EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Redis (BullMQ broker for async email jobs — required once queue worker runs)
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────────────────
# Frontend (Next.js — only NEXT_PUBLIC_* are exposed to the browser)
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost:4000
