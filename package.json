{
  "name": "smart-collab",
  "version": "0.1.0",
  "private": true,
  "description": "Smart Project & Task Collaboration System — EAP 4.0 Assessment",
  "scripts": {
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build",
    "test:backend": "npm --prefix backend test",
    "test:frontend": "npm --prefix frontend test",
    "test": "npm run test:backend && npm run test:frontend",
    "lint:backend": "npm --prefix backend run lint",
    "lint:frontend": "npm --prefix frontend run lint",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "typecheck:backend": "npm --prefix backend run typecheck",
    "typecheck:frontend": "npm --prefix frontend run typecheck",
    "typecheck": "npm run typecheck:backend && npm run typecheck:frontend",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "npm --prefix backend run db:migrate:dev",
    "db:seed": "npm --prefix backend run db:seed"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git"
  },
  "license": "UNLICENSED"
}
